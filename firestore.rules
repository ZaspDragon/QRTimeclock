rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return signedIn() && myProfile().role is string
        ? myProfile().role.lower()
        : '';
    }

    function isAdmin() {
      return myRole().matches('^ *(admin|super[_ -]admin|owner) *$');
    }

    function isManager() {
      return myRole().matches(
        '^ *(admin|manager|supervisor|super[_ -]admin|owner|agency[_ -]admin) *$'
      );
    }

    function isEmployee() {
      return myRole().matches('^ *(employee|worker) *$');
    }

    function canDeletePunches() {
      return myRole().matches('^ *(admin|manager|supervisor|super[_ -]admin|owner) *$');
    }

    function myCompanyId() {
      return myProfile().companyId;
    }

    function sameCompany(resourceData) {
      return signedIn() && resourceData.companyId == myCompanyId();
    }

    function isPublicTimeEmployee(employeeId) {
      return employeeId is string &&
        employeeId.size() > 0 &&
        exists(/databases/$(database)/documents/employees/$(employeeId)) &&
        (
          get(/databases/$(database)/documents/employees/$(employeeId)).data.status == 'active' ||
          (
            get(/databases/$(database)/documents/employees/$(employeeId)).data.status == 'merged' &&
            get(/databases/$(database)/documents/employees/$(employeeId)).data.mergedInto is string &&
            exists(
              /databases/$(database)/documents/employees/$(
                get(/databases/$(database)/documents/employees/$(employeeId)).data.mergedInto
              )
            ) &&
            get(
              /databases/$(database)/documents/employees/$(
                get(/databases/$(database)/documents/employees/$(employeeId)).data.mergedInto
              )
            ).data.status == 'active'
          )
        );
    }

    // ─── companies ───────────────────────────────────────
    match /companies/{companyId} {
      allow read: if signedIn() && myCompanyId() == companyId;
      allow create, update, delete: if isAdmin() && myCompanyId() == companyId;
    }

    // ─── agencies ────────────────────────────────────────
    match /agencies/{agencyId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Optional multi-location settings. Public reads support QR site context;
    // location enforcement remains disabled by the app.
    match /sites/{siteId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        request.resource.data.siteId == siteId &&
        request.resource.data.enforceLocation == false;
      allow delete: if false;
    }

    // ─── users (login accounts) ──────────────────────────
    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        (isManager() && resource.data.companyId == myCompanyId())
      );
      allow create, update: if isAdmin() && request.resource.data.companyId == myCompanyId();
      allow delete: if isAdmin() && resource.data.companyId == myCompanyId();
    }

    // ─── employees (all workers, including temps) ────────
    match /employees/{employeeId} {
      // This deployment contains legacy records with blank companyId values.
      // Managers retain access while agency filtering remains in the UI.
      allow read: if isManager();

      // Public read for autocomplete (QR punch flow, unauthenticated)
      allow read: if resource.data.status == 'active';

      // Public time lookup may resolve retained duplicate IDs to an active primary.
      allow read: if
        resource.data.status == 'merged' &&
        resource.data.mergedInto is string &&
        exists(/databases/$(database)/documents/employees/$(resource.data.mergedInto)) &&
        get(/databases/$(database)/documents/employees/$(resource.data.mergedInto)).data.status == 'active';

      // Manager creates
      allow create: if isManager() && (
        request.resource.data.companyId == myCompanyId() ||
        request.resource.data.companyId == ''
      );

      // Auto-create from public QR punch flow (unauthenticated)
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 80 &&
        request.resource.data.nameKey is string &&
        request.resource.data.employeeNumber is string &&
        request.resource.data.employeeId == employeeId &&
        employeeId.matches('auto_.*') &&
        request.resource.data.status == 'active' &&
        request.resource.data.source == 'auto_created';

      allow update: if isManager();

      // Allow the auto-created doc to write back its own employeeId
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['employeeId']);

      // Employee records are retained so historical punches remain connected.
      allow delete: if false;
    }

    // ─── punches ─────────────────────────────────────────
    match /punches/{punchId} {
      // Public QR punches remain unauthenticated; manual corrections require
      // an approved editing role.
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 80 &&
        request.resource.data.nameKey is string &&
        request.resource.data.nameKey.size() >= 2 &&
        request.resource.data.action in ['clock_in', 'start_lunch', 'end_lunch', 'clock_out'] &&
        request.resource.data.dateKey is string &&
        request.resource.data.weekKey is string &&
        request.resource.data.timestampMs is number &&
        (
          (!signedIn() && request.resource.data.source == 'public_qr') ||
          (
            isManager() &&
            request.resource.data.source in ['manual_manager', 'missed_punch_approved']
          )
        );

      // Managers/admins read current and legacy punches.
      allow read: if isManager();

      // No-login worker history is read-only and remains tied to an active
      // employee ID. Blank IDs support legacy punches, filtered by name in UI.
      allow read: if
        isPublicTimeEmployee(resource.data.get('employeeId', '')) ||
        resource.data.get('employeeId', '') == '';

      // Employees read only their own punches.
      allow read: if isEmployee() &&
        resource.data.employeeId == myProfile().employeeId;

      // Managers/supervisors/admins can fix punch times and retained legacy punches.
      allow update: if isManager();

      // Delete is intentionally role-gated, not company-gated, because older
      // punches may have blank or missing companyId values. This changes access
      // only; it does not delete any existing data by itself.
      allow delete: if canDeletePunches();
    }

    // ─── punch_edits (audit trail) ───────────────────────
    match /punch_edits/{editId} {
      allow create: if isManager();
      allow read: if isManager();
    }

    match /auditLogs/{auditId} {
      allow create, read: if isManager();
      allow update, delete: if false;
    }

    // ─── timesheets ──────────────────────────────────────
    match /timesheets/{timesheetId} {
      allow read: if isManager();

      // Employees can read their own timesheets
      allow read: if isEmployee() &&
        resource.data.employeeId == myProfile().employeeId;

      allow create: if isManager() && request.resource.data.companyId == myCompanyId();
      allow update: if isManager();
      allow delete: if isAdmin() && sameCompany(resource.data);
    }

    // ─── missedPunchRequests ─────────────────────────────
    match /missedPunchRequests/{requestId} {
      // Signed-in employees create requests for themselves. Public workers may
      // submit a pending request only for an existing active employee selected
      // by name; the request cannot edit or create a punch by itself.
      allow create: if (
        signedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.companyId == myCompanyId() &&
        request.resource.data.status == 'pending'
      ) || (
        !signedIn() &&
        request.resource.data.source == 'public_worker' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.employeeId is string &&
        request.resource.data.employeeId.size() > 0 &&
        exists(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)) &&
        get(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)).data.status == 'active' &&
        request.resource.data.name == get(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)).data.name &&
        request.resource.data.companyId == get(/databases/$(database)/documents/employees/$(request.resource.data.employeeId)).data.companyId &&
        request.resource.data.requestedAction in ['clock_in', 'start_lunch', 'end_lunch', 'clock_out'] &&
        request.resource.data.requestedTimestampMs is number &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() >= 2 &&
        request.resource.data.reason.size() <= 300
      );

      // Employees read their own requests
      allow read: if signedIn() && resource.data.uid == request.auth.uid;

      // Managers/admins read current and legacy requests.
      allow read: if isManager();

      // Managers/admins can approve/deny
      allow update: if isManager();
    }
  }
}
